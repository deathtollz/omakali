#!/bin/bash

# omari:summary=Install Cursor AI editor

echo "Installing Cursor..."
flatpak install -y flathub com.todesktop.230113mqtodmhsu 2>/dev/null || {
  echo "Downloading Cursor..."
  curl -fsSL "https://cursor.sh/downloads/linux/appImage" -o /tmp/cursor.AppImage
  mkdir -p ~/.local/share/cursor
  install /tmp/cursor.AppImage ~/.local/share/cursor/cursor.AppImage
  echo "Cursor installed to ~/.local/share/cursor/"
}
