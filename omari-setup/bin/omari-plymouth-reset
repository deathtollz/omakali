#!/bin/bash

# omari:summary=Restore the default Omari Plymouth boot themen
# omari:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/omari"

sudo find ~/.local/share/omari/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo update-alternatives --install /usr/share/plymouth/themes/default.plymouth default.plymouth /usr/share/plymouth/themes/omari/omari.plymouth 100
sudo update-alternatives --set default.plymouth /usr/share/plymouth/themes/omari/omari.plymouth
sudo update-initramfs -u
