#!/bin/bash

# omari:summary=Overwrite the user configs for Walker (app launcher and Omari Menu) and restart the services.

mkdir -p ~/.config/autostart/
cp $OMARI_PATH/default/walker/walker.desktop ~/.config/autostart/

# And restarts if it crashes or is killed
mkdir -p ~/.config/systemd/user/app-walker@autostart.service.d/
cp $OMARI_PATH/default/walker/restart.conf ~/.config/systemd/user/app-walker@autostart.service.d/restart.conf

systemctl --user daemon-reload

# Refresh configs
omari-refresh-config walker/config.toml
omari-refresh-config elephant/calc.toml
omari-refresh-config elephant/desktopapplications.toml

# Link all elephant menus
mkdir -p ~/.config/elephant/menus
for menu in $OMARI_PATH/default/elephant/*.lua; do
  ln -snf "$menu" ~/.config/elephant/menus/"$(basename "$menu")"
done

# Restart service
omari-restart-walker
