  *JetBrains*) remove_font "JetBrains Mono" "jetbrains-mono" ;;
  *iA*) remove_font "iA Fonts" "iafonts" ;;
  *Microsoft*) remove_font "Microsoft Core Fonts" "mscore" ;;
  *) show_remove_menu ;;
  esac
}

