show_update_menu() {
  local brand_name=$(omari-branding-name)

  case $(menu "Update" "у°ҹў  $brand_name\nу°”«  Channel\nоҳ•  Config\nу°ёҢ  Themes\nо®ў  Process\nу°Ү…  Hardware\nо©ё  Firmware\nо¬‘  Password\nоҺғ  Time") in
  *$brand_name*) present_terminal omari-update ;;
  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal omari-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal omari-update-firmware ;;
  *Password*) show_update_password_menu ;;
  *Time*) present_terminal "sudo timedatectl set-ntp true && sudo systemctl restart systemd-timesyncd" ;;
  *) show_main_menu ;;
  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "рҹҹў Stable\nрҹ”ҙ Dev") in
  *Stable*) present_terminal "omari-channel-set stable" ;;
  *Dev*) present_terminal "omari-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "оҪ¶  Niri\nп„ң  Keybindings\nуұЈҙ  Plymouth\nп„ө  Starship\nоҜҲ  Tmux\nу°Ң§  Walker") in
  *Niri*) present_terminal omari-refresh-niri ;;
  *Keybindings*) present_terminal omari-refresh-keybindings ;;
  *Plymouth*) present_terminal omari-refresh-plymouth ;;
  *Starship*) present_terminal omari-refresh-config starship.toml ;;
  *Tmux*) present_terminal omari-refresh-tmux ;;
  *Walker*) present_terminal omari-refresh-walker ;;
  *) show_update_menu ;;
  esac
}

show_update_process_menu() {
  case $(menu "Restart" "у°Ң§  Walker\nу°Қң  Waybar\nу°Ӯӣ  Mako\nоҪ¶  Niri") in
  *Walker*) omari-restart-walker ;;
  *Waybar*) omari-restart-waybar ;;
  *Mako*) omari-restart-mako 2>/dev/null || true ;;
  *Niri*) niri msg action quit 2>/dev/null || true ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "оҳё  Audio\nу°ӮҜ  Bluetooth") in
  *Audio*) present_terminal omari-restart-pipewire ;;
  *Bluetooth*) present_terminal omari-restart-bluetooth ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "о¬‘  User") in
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  omari-launch-about
}

show_system_menu() {
  local options="у°Ңҫ  Lock"
  [[ ! -f ~/.local/state/omari/toggles/suspend-off ]] && options="$options\nу°’І  Suspend"
  options="$options\nу°Ңҫ  Logout\nу°ңү  Restart\nу°җҘ  Shutdown"

  case $(menu "System" "$options") in
  *Lock*) omari-system-lock ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) omari-system-logout ;;
  *Restart*) omari-system-reboot ;;
  *Shutdown*) omari-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "у°Җ»  Apps\nу°§‘  Learn\nуұ“һ  Trigger\nоҜҸ  Style\nоҳ•  Setup\nу°үү  Install\nу°ӯҢ  Remove\nу°‘җ  Update\nо©ҙ  About\nу°ӨҶ  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "Launch..." ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *share*) show_share_menu ;;
  *reminder-set*) show_custom_reminder_input ;;
  *reminder*) show_reminder_menu ;;
  *capture*) show_capture_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *hardware*) show_hardware_menu ;;
  *background*) show_background_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *security*) show_setup_security_menu ;;
  *battery*) show_setup_battery_menu ;;
  *install*) show_install_menu ;;
  *gaming*) show_install_gaming_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omari/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi