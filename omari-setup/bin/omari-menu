  case $(menu "Install" "  Package\n  Web App\n  TUI\n  Service\n  Browser\n  Style\n󰵮  Development\n  Editor\n  Terminal") in
  *Package*) terminal omari-pkg-install ;;
  *Web*) present_terminal omari-webapp-install ;;
  *TUI*) present_terminal omari-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Browser*) show_install_browser_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *) show_main_menu ;;
  esac
}

