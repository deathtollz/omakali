#!/bin/bash

# omari:summary=Launch the Omari Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/omari/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omari-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptтАж" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec "$@"
}

present_terminal() {
  omari-launch-floating-terminal-with-presentation "$@"
}

open_in_editor() {
  omari-notification-send -g "ґ░Во" -u low "Editing config file" "$1"
  omari-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omari-pkg-add $2"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omari-install-font $2 && sleep 2 && omari-font-set '$3'"
}

install_terminal() {
  present_terminal "omari-install-terminal $1"
}

remove() {
  present_terminal "echo 'Removing $1...'; omari-pkg-drop $2"
}

remove_font() {
  present_terminal "echo 'Removing $1...'; omari-remove-font $2"
}

show_learn_menu() {
  case $(menu "Learn" "яДЬ  Keybindings\nяТЙ  Tmux keybindings\nяРЕ  Omari\nяМз  Kali Wiki\nяМЖ  Debian\nю╜╢  Niri\nюЪо  Neovim\nґ▒ЖГ  Bash") in
  *Keybindings*) omari-launch-webapp "https://omari.omakasui.org/manual/essentials/hotkeys" "Omari Keybindings" ;;
  *Tmux*) omari-menu-tmux-keybindings ;;
  *Omari*) omari-launch-webapp "https://omari.omakasui.org/manual" "Omari" ;;
  *Kali*) omari-launch-webapp "https://www.kali.org/docs/" "Kali Wiki" ;;
  *Debian*) omari-launch-webapp "https://www.debian.org/doc/" "Debian" ;;
  *Niri*) omari-launch-webapp "https://niri-wm.github.io/niri/" "Niri" ;;
  *Bash*) omari-launch-webapp "https://devhints.io/bash" "Bash" ;;
  *Neovim*) omari-launch-webapp "https://www.lazyvim.org/keymaps" "Neovim" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ґ░ФЫ  Reminder\nґ░з╕  Transcode\nяА░  Capture\nяФО  Share\nґ░ФО  Toggle\nю╜░  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Transcode*) omari-transcode || back_to show_trigger_menu ;;
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "яА░  Screenshot\nяА╜  Screenrecord\nґ░┤С  Text Extraction\nґ░ГЙ  Color Picker") in
  *Screenshot*) omari-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) omari-capture-text-extraction ;;
  *Color*) pkill hyprpicker 2>/dev/null || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_screenrecord_menu() {
  # Check if currently recording
  if pgrep -f "gpu-screen-recorder" >/dev/null 2>&1; then
    case $(menu "Screenrecord" "ґ░╗Г  Stop Recording") in
    *Stop*) omari-capture-screenrecording --stop-recording 2>/dev/null || true ;;
    *) back_to show_capture_menu ;;
    esac
    return
  fi

  case $(menu "Screenrecord" "ґ░╗Г  Screen\nґ░╗Г  Screen + Audio\nґ░йн  Region\nґ░йн  Region + Audio\nґ▒ВГ  Webcam Select") in
  *Screen\ +\ Audio*) omari-capture-screenrecording --portal --with-desktop-audio ;;
  *Screen*) omari-capture-screenrecording --portal ;;
  *Region\ +\ Audio*) omari-capture-screenrecording --with-desktop-audio ;;
  *Region*) omari-capture-screenrecording ;;
  *Webcam*) show_webcam_select_menu ;;
  *) back_to show_capture_menu ;;
  esac
}

show_webcam_select_menu() {
  local cams=""
  while IFS= read -r dev; do
    [[ -n "$dev" ]] && cams="${cams}ґ░╗Г  $dev
"
  done < <(find /dev/video* 2>/dev/null | sort | head -8)

  if [[ -z "$cams" ]]; then
    omari-notification-send -g "ґ░┤С" "Webcam" "No webcam devices found" 2>/dev/null || true
    back_to show_capture_menu
    return
  fi

  local selected
  selected=$(menu "Webcam" "$(echo -e "$cams")" "--width 350")
  if [[ $selected == "CNCLD" || -z $selected ]]; then
    back_to show_capture_menu
  else
    omari-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$selected"
  fi
}

show_hardware_menu() {
  local options="ґ░Ыз  Laptop Display\nґ░Н╣  Mirror Display"

  if omari-hw-touchpad 2>/dev/null; then
    options="$options\nґ░Я╕  Touchpad"
  fi

  if [[ -f "$HOME/.config/omari/state/touchscreen-device" ]] || libinput list-devices 2>/dev/null | grep -q "Touchscreen"; then
    options="$options\nґ░ММ  Touchscreen"
  fi

  if ls /sys/class/drm/card*-mipi* /sys/class/drm/card*-eDP* >/dev/null 2>&1 || ls /sys/class/drm/card1*/device/power_dpm_force_performance_level >/dev/null 2>&1; then
    options="$options\nґ░╣С  Hybrid GPU"
  fi

  case $(menu "Hardware" "$options") in
  *Laptop*) omari-niri-monitor-internal toggle ;;
  *Mirror*) omari-niri-monitor-internal-mirror toggle ;;
  *Touchpad*) omari-toggle-touchpad ;;
  *Touchscreen*) omari-toggle-touchscreen ;;
  *Hybrid*) present_terminal "omari-toggle-hybrid-gpu" 2>/dev/null || \
    notify-send -t 3000 "Hybrid GPU" "Not available on this system" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "ґ░ФЫ  Set one\nґ░ФЫ  Show all\nґ░ФЫ  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) omari-reminder show ;;
  *"Clear all"*) omari-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(omari-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omari-notification-send -g "ґ░ФЫ" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omari-menu-input "Reminder message")

  if [[ -n $message ]]; then
    omari-reminder "$minutes" "$message"
  else
    omari-reminder "$minutes"
  fi
}

show_share_menu() {
  case $(menu "Share" "яБ┐  Clipboard\nюй╗  File \nяДФ  Folder\nґ░еж  Receive") in
  *Receive*) localsend_app ;;
  *Clipboard*) omari-menu-share clipboard ;;
  *File*) terminal bash -c "omari-menu-share file" ;;
  *Folder*) terminal bash -c "omari-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="ґ▒ДД  Screensaver\nґ░ФО  Nightlight\nґ▒лЦ  Idle Lock\nґ░ВЫ  Notifications\nґ░НЬ  Top Bar\nґ▒Вм  Workspace Layout\nюШк  Window Gaps\nґ░Н╣  Monitor Scaling\nґ░Г░  1-Window Ratio\nґ▒еА  Direct Boot\nюмС  Passwordless Sudo"

  case $(menu "Toggle" "$options") in
  *Screensaver*) omari-toggle-screensaver ;;
  *Nightlight*) omari-toggle-nightlight ;;
  *Idle*) omari-toggle-idle ;;
  *Notifications*) omari-toggle-notification-silencing ;;
  *Bar*) omari-toggle-waybar ;;
  *Layout*) omari-niri-workspace-layout-toggle ;;
  *Gaps*) omari-niri-window-gaps-toggle ;;
  *Scaling*) omari-niri-monitor-scaling-cycle ;;
  *1-Window*) omari-niri-window-single-square-aspect-toggle 2>/dev/null || \
    notify-send -t 3000 "1-Window Ratio" "Feature not available - install niri-git or use Niri 26+" ;;
  *Direct\ Boot*) present_terminal "omari-config-direct-boot" 2>/dev/null || \
    notify-send -t 3000 "Direct Boot" "Feature not available on this system" ;;
  *Passwordless*) present_terminal "omari-sudo-passwordless" 2>/dev/null || \
    notify-send -t 3000 "Passwordless Sudo" "Feature not available on this system" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "ґ░╕М  Theme\nґ░Я╡  Unlock\nюЩЩ  Font\nяА╛  Background\nґ░и│  Niri\nґ▒ДД  Screensaver\nюй┤  About") in
  *Theme*) show_theme_menu ;;
  *Unlock*) omari-launch-walker -m menus:omariunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Niri*) open_in_editor ~/.config/niri/looknfeel.kdl ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_screensaver_menu() {
  case $(menu "Screensaver" "яБД  Edit Text\nяА╛  Set From Image\nяСк  Restore Default") in
  *Text*) omari-branding-screensaver text ;;
  *Image*) omari-branding-screensaver image ;;
  *Default*) omari-branding-screensaver reset ;;
  *) show_style_menu ;;
  esac
}

show_theme_menu() {
  omari-launch-walker -m menus:omarithemes --width 800 --minheight 400
}

show_font_menu() {
  font=$(menu "Font" "$(omari-font-list)" "--width 350" "$(omari-font-current)")
  if [[ $font == "CNCLD" || -z $font ]]; then
    back_to show_style_menu
  else
    omari-font-set "$font"
  fi
}

show_background_menu() {
  omari-launch-walker -m menus:omariBackgroundSelector --width 800 --minheight 400
}

show_about_menu() {
  case $(menu "About" "яБД  Edit Text\nяА╛  Set From Image\nяСк  Restore Default") in
  *Text*) omari-branding-about text ;;
  *Image*) omari-branding-about image ;;
  *Default*) omari-branding-about reset ;;
  *) show_style_menu ;;
  esac
}

show_setup_menu() {
  local options="юШ╕  Audio\nяЗл  Wifi\nґ░Вп  Bluetooth\nґ▒РЛ  Power Profile\nґ░дЖ  System Sleep\nюкГ  Folders\nґ░ВБ  Battery\nяДЬ  Keybindings\nґ░ЯБ  Monitors\nґ▒Мв  Input\nґ░УО  Defaults\nґ░▒Ф  DNS\nюмС  Security\nюШХ  Config"

  case $(menu "Setup" "$options") in
  *Audio*) omari-launch-audio ;;
  *Wifi*) omari-launch-wifi ;;
  *Bluetooth*) omari-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Battery*) show_setup_battery_menu ;;
  *Keybindings*) open_in_editor ~/.config/niri/bindings.kdl ;;
  *Monitors*) open_in_editor ~/.config/niri/monitors.kdl ;;
  *Input*) open_in_editor ~/.config/niri/input.kdl ;;
  *Folders*) xdg-open "$HOME" 2>/dev/null || nautilus "$HOME" & ;;
  *Defaults*) show_setup_default_menu ;;
  *DNS*) present_terminal omari-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_battery_menu() {
  case $(menu "Battery" "ґ▒ИП  Limit Charging (80%)\nґ░Б╣  Full Charging (100%)") in
  *Limit*) present_terminal "sudo asusctl battery limit 80" 2>/dev/null || \
    present_terminal "echo 'Battery charge limiting requires asusctl.\n\nInstall it with: omari-pkg-add asusctl'" ;;
  *Full*) present_terminal "sudo asusctl battery oneshot" 2>/dev/null || \
    present_terminal "echo 'Resetting to full charge mode requires asusctl.'" ;;
  *) show_setup_menu ;;
  esac
}

show_setup_security_menu() {
  case $(menu "Security" "ґ░И╖  Fingerprint\nюмС  Fido2") in
  *Fingerprint*) present_terminal omari-setup-security-fingerprint 2>/dev/null || \
    present_terminal "echo 'Fingerprint enrollment requires fprintd.\n\nMake sure your device has a fingerprint reader.\n\nRun: sudo fprintd-enroll'" ;;
  *Fido2*) present_terminal omari-setup-security-fido2 2>/dev/null || \
    present_terminal "echo 'Fido2 security key setup is not yet available for Kali.\nSee: https://developers.yubico.com/libfido2/'" ;;
  *) show_setup_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(omari-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_system_menu() {
  local options=""

 if omari-toggle-enable suspend-off; then
    options="$optionsґ░Т▓  Enable Suspend"
  else
    options="$optionsґ░Т▓  Disable Suspend"
  fi

  if [[ -f /etc/initramfs-tools/conf.d/resume ]] || command -v hibernate >/dev/null 2>&1; then
    options="$options\nґ░дБ  Hibernate"
  fi

  case $(menu "System Sleep" "$options") in
  *Suspend*) omari-toggle-suspend ;;
  *Hibernate*) present_terminal "omari-hibernation-setup" 2>/dev/null || \
    present_terminal "echo 'Hibernate configuration requires a swap partition or file with a resume offset.\n\nSee: https://wiki.debian.org/Hibernation'" ;;
  *) show_setup_menu ;;
  esac
}

show_setup_default_menu() {
  case $(menu "Default" "яТИ  Browser\nяТЙ  Terminal\nяЕЬ  Editor") in
  *Browser*) show_setup_default_browser_menu ;;
  *Terminal*) show_setup_default_terminal_menu ;;
  *Editor*) show_setup_default_editor_menu ;;
  *) show_setup_menu ;;
  esac
}

browser_desktop_exists() {
  [[ -f ~/.local/share/applications/$1 || -f ~/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

show_setup_default_browser_menu() {
  local options=""
  browser_desktop_exists chromium.desktop && options="$optionsяЙи  Chromium"
  browser_desktop_exists google-chrome.desktop && options="${options:+$options\n}ґ░Кп  Chrome"
  browser_desktop_exists brave-browser.desktop && options="${options:+$options\n}ґ░ЦЯ  Brave"
  browser_desktop_exists brave-browser-origin.desktop && options="${options:+$options\n}ґ░ЦЯ  Brave Origin"
  browser_desktop_exists microsoft-edge.desktop && options="${options:+$options\n}ґ░Зй  Edge"
  browser_desktop_exists firefox.desktop && options="${options:+$options\n}ґ░И╣  Firefox"
  browser_desktop_exists zen.desktop && options="${options:+$options\n}ґ░ЦЯ  Zen"

  local current=""
  case "$(omari-default-browser)" in
  chromium) current="яЙи  Chromium" ;;
  chrome) current="ґ░Кп  Chrome" ;;
  brave) current="ґ░ЦЯ  Brave" ;;
  brave-origin) current="ґ░ЦЯ  Brave Origin" ;;
  edge) current="ґ░Зй  Edge" ;;
  firefox) current="ґ░И╣  Firefox" ;;
  zen) current="ґ░ЦЯ  Zen" ;;
  esac

  case $(menu "Default Browser" "$options" "" "$current") in
  *Chromium*) omari-default-browser chromium ;;
  *Chrome*) omari-default-browser chrome ;;
  *Brave\ Origin*) omari-default-browser brave-origin ;;
  *Brave*) omari-default-browser brave ;;
  *Edge*) omari-default-browser edge ;;
  *Firefox*) omari-default-browser firefox ;;
  *Zen*) omari-default-browser zen ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_terminal_menu() {
  local options=""
  omari-cmd-present alacritty && options="$optionsюЮХ  Alacritty"
  omari-cmd-present ghostty && options="${options:+$options\n}юЮХ  Ghostty"
  omari-cmd-present kitty && options="${options:+$options\n}юЮХ  Kitty"
  omari-cmd-present foot && options="${options:+$options\n}юЮХ  Foot"

  local current=""
  case "$(omari-default-terminal)" in
  alacritty) current="юЮХ  Alacritty" ;;
  ghostty) current="юЮХ  Ghostty" ;;
  kitty) current="юЮХ  Kitty" ;;
  foot) current="юЮХ  Foot" ;;
  esac

  case $(menu "Default Terminal" "$options" "" "$current") in
  *Alacritty*) omari-default-terminal alacritty ;;
  *Ghostty*) omari-default-terminal ghostty ;;
  *Kitty*) omari-default-terminal kitty ;;
  *Foot*) omari-default-terminal foot ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_editor_menu() {
  local options=""
  omari-cmd-present nvim && options="$optionsюЪо  Neovim"
  omari-cmd-present code && options="${options:+$options\n}югЪ  VSCode"
  omari-cmd-present zeditor && options="${options:+$options\n}яЕЬ  Zed"
  omari-cmd-present vim && options="${options:+$options\n}юШл  Vim"
  omari-cmd-present hx && options="${options:+$options\n}ґ░иЮ  Helix"
  omari-cmd-present emacs && options="${options:+$options\n}ґ░Ы│  Emacs"
  omari-cmd-present cursor && options="${options:+$options\n}ґ░ЗЕ  Cursor"
  omari-cmd-present sublime_text && options="${options:+$options\n}ґ░Ш░  Sublime Text"

  local current=""
  case "$(omari-default-editor)" in
  nvim) current="юЪо  Neovim" ;;
  code) current="югЪ  VSCode" ;;
  zed | zeditor) current="яЕЬ  Zed" ;;
  vim) current="юШл  Vim" ;;
  hx) current="ґ░иЮ  Helix" ;;
  emacs) current="ґ░Ы│  Emacs" ;;
  cursor) current="ґ░ЗЕ  Cursor" ;;
  sublime_text) current="ґ░Ш░  Sublime Text" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) omari-default-editor nvim ;;
  *VSCode*) omari-default-editor code ;;
  *Zed*) omari-default-editor zed ;;
  *Vim*) omari-default-editor vim ;;
  *Helix*) omari-default-editor hx ;;
  *Emacs*) omari-default-editor emacs ;;
  *Cursor*) omari-default-editor cursor ;;
  *Sublime*) omari-default-editor sublime_text ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "ґ░и│  Niri\nґ░Мз  Walker\nґ░НЬ  Waybar\nґ░ВЫ  Mako\nяД╡  Starship\nюпИ  Tmux\nяТЙ  Alacritty\nґ░Ка  GTK\nю╜▓  APT") in
  *Niri*) open_in_editor ~/.config/niri/config.kdl ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && omari-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omari-restart-waybar ;;
  *Mako*) open_in_editor ~/.config/mako/config && omari-restart-mako ;;
  *Starship*) open_in_editor ~/.config/starship.toml ;;
  *Tmux*) open_in_editor ~/.config/tmux/tmux.conf && omari-restart-tmux ;;
  *Alacritty*) open_in_editor ~/.config/alacritty/alacritty.toml ;;
  *GTK*) open_in_editor ~/.config/gtk-3.0/settings.ini ;;
  *APT*) present_terminal "sudo nano /etc/apt/sources.list" ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "ю╜▓  Package\nяЙи  Web App\nяТЙ  TUI\nяТЗ  Service\nяВм  Browser\nюпП  Style\nґ░╡о  Development\nяЕЬ  Editor\nяТЙ  Terminal\nґ▒Ъд  AI\nяДЫ  Gaming") in
  *Package*) terminal omari-pkg-install ;;
  *Web*) present_terminal omari-webapp-install ;;
  *TUI*) present_terminal omari-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Browser*) show_install_browser_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "яТЗ  Bitwarden\nяЗ┐  Discord\nяН╢  LibreOffice\nяТЗ  LocalSend\nяТЗ  ObsStudio\nяЖ╝  Spotify\nяТЗ  Tailscale") in
  *Bitwarden*) install "Bitwarden" "bitwarden" ;;
  *Discord*) present_terminal omari-install-discord ;;
  *LibreOffice*) install "LibreOffice" "libreoffice" ;;
  *LocalSend*) install "LocalSend" "localsend" ;;
  *ObsStudio*) install "ObsStudio" "obs-studio" ;;
  *Spotify*) present_terminal omari-install-spotify ;;
  *Tailscale*) present_terminal omari-install-tailscale ;;
  *) show_install_menu ;;
  esac
}

show_install_browser_menu() {
  case $(menu "Install" "яЙи  Chrome\nяЙи  Edge\nяЙи  Brave Origin\nяЙи  Brave\nяЙй  Firefox\nґ░ЦЯ  Zen") in
  *Chrome*) present_terminal "omari-install-browser chrome" ;;
  *Edge*) present_terminal "omari-install-browser edge" ;;
  *Brave\ Origin*) present_terminal "omari-install-browser brave-origin" ;;
  *Brave*) present_terminal "omari-install-browser brave" ;;
  *Firefox*) present_terminal "omari-install-browser firefox" ;;
  *Zen*) present_terminal "omari-install-browser zen" ;;
  *) show_install_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "ґ░╕М  Theme\nяА╛  Background\nюЩЩ  Font") in
  *Theme*) present_terminal omari-theme-install ;;
  *Background*) omari-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
