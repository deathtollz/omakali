#!/bin/bash

# omari:summary=Launch the Omari Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/omari/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omari-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptвҖҰ" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec "$@"
}

present_terminal() {
  omari-launch-floating-terminal-with-presentation "$@"
}

open_in_editor() {
  omari-notification-send -g "у°Ӯ®" -u low "Editing config file" "$1"
  omari-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omari-pkg-add $2"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omari-install-font $2 && sleep 2 && omari-font-set '$3'"
}

install_terminal() {
  present_terminal "omari-install-terminal $1"
}

remove() {
  present_terminal "echo 'Removing $1...'; omari-pkg-drop $2"
}

remove_font() {
  present_terminal "echo 'Removing $1...'; omari-remove-font $2"
}

show_learn_menu() {
  case $(menu "Learn" "п„ң  Keybindings\nп’ү  Tmux keybindings\nпҗ…  Omari\nпҢ§  Kali Wiki\nпҢҶ  Debian\nоҪ¶  Niri\nоҡ®  Neovim\nуұҶғ  Bash") in
  *Keybindings*) omari-launch-webapp "https://omari.omakasui.org/manual/essentials/hotkeys" "Omari Keybindings" ;;
  *Tmux*) omari-menu-tmux-keybindings ;;
  *Omari*) omari-launch-webapp "https://omari.omakasui.org/manual" "Omari" ;;
  *Kali*) omari-launch-webapp "https://www.kali.org/docs/" "Kali Wiki" ;;
  *Debian*) omari-launch-webapp "https://www.debian.org/doc/" "Debian" ;;
  *Niri*) omari-launch-webapp "https://niri-wm.github.io/niri/" "Niri" ;;
  *Bash*) omari-launch-webapp "https://devhints.io/bash" "Bash" ;;
  *Neovim*) omari-launch-webapp "https://www.lazyvim.org/keymaps" "Neovim" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "у°”ӣ  Reminder\nу°§ё  Transcode\nпҖ°  Capture\nп”Һ  Share\nу°”Һ  Toggle\nоҪ°  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Transcode*) omari-transcode || back_to show_trigger_menu ;;
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ҙ‘  Text Extraction\nу°ғү  Color Picker") in
  *Screenshot*) omari-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) omari-capture-text-extraction ;;
  *Color*) pkill hyprpicker 2>/dev/null || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_screenrecord_menu() {
  # Check if currently recording
  if pgrep -f "gpu-screen-recorder" >/dev/null 2>&1; then
    case $(menu "Screenrecord" "у°»ғ  Stop Recording") in
    *Stop*) omari-capture-screenrecording --stop-recording 2>/dev/null || true ;;
    *) back_to show_capture_menu ;;
    esac
    return
  fi

  case $(menu "Screenrecord" "у°»ғ  Screen\nу°»ғ  Screen + Audio\nу°©ӯ  Region\nу°©ӯ  Region + Audio\nуұӮғ  Webcam Select") in
  *Screen\ +\ Audio*) omari-capture-screenrecording --portal --with-desktop-audio ;;
  *Screen*) omari-capture-screenrecording --portal ;;
  *Region\ +\ Audio*) omari-capture-screenrecording --with-desktop-audio ;;
  *Region*) omari-capture-screenrecording ;;
  *Webcam*) show_webcam_select_menu ;;
  *) back_to show_capture_menu ;;
  esac
}

show_webcam_select_menu() {
  local cams=""
  while IFS= read -r dev; do
    [[ -n "$dev" ]] && cams="${cams}у°»ғ  $dev
"
  done < <(find /dev/video* 2>/dev/null | sort | head -8)

  if [[ -z "$cams" ]]; then
    omari-notification-send -g "у°ҙ‘" "Webcam" "No webcam devices found" 2>/dev/null || true
    back_to show_capture_menu
    return
  fi

  local selected
  selected=$(menu "Webcam" "$(echo -e "$cams")" "--width 350")
  if [[ $selected == "CNCLD" || -z $selected ]]; then
    back_to show_capture_menu
  else
    omari-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$selected"
  fi
}

show_hardware_menu() {
  local options="у°ӣ§  Laptop Display\nу°Қ№  Mirror Display"

  if omari-hw-touchpad 2>/dev/null; then
    options="$options\nу°ҹё  Touchpad"
  fi

  if [[ -f "$HOME/.config/omari/state/touchscreen-device" ]] || libinput list-devices 2>/dev/null | grep -q "Touchscreen"; then
    options="$options\nу°ҢҢ  Touchscreen"
  fi

  case $(menu "Hardware" "$options") in
  *Laptop*) omari-niri-monitor-internal toggle ;;
  *Mirror*) omari-niri-monitor-internal-mirror toggle ;;
  *Touchpad*) omari-toggle-touchpad ;;
  *Touchscreen*) omari-toggle-touchscreen ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "у°”ӣ  Set one\nу°”ӣ  Show all\nу°”ӣ  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) omari-reminder show ;;
  *"Clear all"*) omari-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(omari-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omari-notification-send -g "у°”ӣ" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omari-menu-input "Reminder message")

  if [[ -n $message ]]; then
    omari-reminder "$minutes" "$message"
  else
    omari-reminder "$minutes"
  fi
}

show_share_menu() {
  case $(menu "Share" "пҒҝ  Clipboard\nо©»  File \nп„”  Folder\nу°ҘҰ  Receive") in
  *Receive*) localsend_app ;;
  *Clipboard*) omari-menu-share clipboard ;;
  *File*) terminal bash -c "omari-menu-share file" ;;
  *Folder*) terminal bash -c "omari-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="у°”Һ  Nightlight\nуұ«–  Idle Lock\nу°Ӯӣ  Notifications\nу°Қң  Top Bar\nуұӮ¬  Layout\nоҳӘ  Window Gaps\nу°Қ№  Scaling"

  if command -v hyprlock >/dev/null 2>&1; then
    options="$options\nуұ„„  Screensaver"
  fi

  case $(menu "Toggle" "$options") in
  *Nightlight*) omari-toggle-nightlight ;;
  *Idle*) omari-toggle-idle ;;
  *Notifications*) omari-toggle-notification-silencing ;;
  *Top*) omari-toggle-waybar ;;
  *Layout*) omari-niri-workspace-layout-toggle ;;
  *Gaps*) omari-niri-window-gaps-toggle ;;
  *Scaling*) omari-niri-monitor-scaling-cycle ;;
  *Screensaver*) omari-launch-screensaver force 2>/dev/null || \
    notify-send -t 2000 "Screensaver" "Press a key to dismiss" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "у°ёҢ  Theme\nу°ҹө  Unlock\nоҷҷ  Font\nпҖҫ  Background\nу°Ёі  Niri\nуұ„„  Screensaver\nо©ҙ  About") in
  *Theme*) show_theme_menu ;;
  *Unlock*) omari-launch-walker -m menus:omariunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Niri*) open_in_editor ~/.config/niri/looknfeel.kdl ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_screensaver_menu() {
  case $(menu "Screensaver" "пҒ„  Edit Text\nпҖҫ  Set From Image\nп‘Ә  Restore Default") in
  *Text*) omari-branding-screensaver text ;;
  *Image*) omari-branding-screensaver image ;;
  *Default*) omari-branding-screensaver reset ;;
  *) show_style_menu ;;
  esac
}

show_theme_menu() {
  omari-launch-walker -m menus:omarithemes --width 800 --minheight 400
}

show_font_menu() {
  font=$(menu "Font" "$(omari-font-list)" "--width 350" "$(omari-font-current)")
  if [[ $font == "CNCLD" || -z $font ]]; then
    back_to show_style_menu
  else
    omari-font-set "$font"
  fi
}

show_background_menu() {
  omari-launch-walker -m menus:omariBackgroundSelector --width 800 --minheight 400
}

show_about_menu() {
  case $(menu "About" "пҒ„  Edit Text\nпҖҫ  Set From Image\nп‘Ә  Restore Default") in
  *Text*) omari-branding-about text ;;
  *Image*) omari-branding-about image ;;
  *Default*) omari-branding-about reset ;;
  *) show_style_menu ;;
  esac
}

show_setup_menu() {
  local options="оҳё  Audio\nпҮ«  Wifi\nу°ӮҜ  Bluetooth\nуұҗӢ  Power Profile\nу°ӨҶ  System Sleep\nоӘғ  Folders\nу°ӮҒ  Battery\nп„ң  Keybindings\nу°“Һ  Defaults\nу°ұ”  DNS\nо¬‘  Security\nоҳ•  Config"

  case $(menu "Setup" "$options") in
  *Audio*) omari-launch-audio ;;
  *Wifi*) omari-launch-wifi ;;
  *Bluetooth*) omari-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Battery*) show_setup_battery_menu ;;
  *Keybindings*) open_in_editor ~/.config/niri/bindings.kdl ;;
  *Folders*) xdg-open "$HOME" 2>/dev/null || nautilus "$HOME" & ;;
  *Defaults*) show_setup_default_menu ;;
  *DNS*) present_terminal omari-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_battery_menu() {
  case $(menu "Battery" "уұҲҸ  Limit Charging (80%)\nу°Ғ№  Full Charging (100%)") in
  *Limit*) present_terminal "sudo asusctl battery limit 80" 2>/dev/null || \
    present_terminal "echo 'Battery charge limiting requires asusctl.\n\nInstall it with: omari-pkg-add asusctl'" ;;
  *Full*) present_terminal "sudo asusctl battery oneshot" 2>/dev/null || \
    present_terminal "echo 'Resetting to full charge mode requires asusctl.'" ;;
  *) show_setup_menu ;;
  esac
}

show_setup_security_menu() {
  case $(menu "Security" "у°Ҳ·  Fingerprint\nо¬‘  Fido2") in
  *Fingerprint*) present_terminal omari-setup-security-fingerprint 2>/dev/null || \
    present_terminal "echo 'Fingerprint enrollment requires fprintd.\n\nMake sure your device has a fingerprint reader.\n\nRun: sudo fprintd-enroll'" ;;
  *Fido2*) present_terminal omari-setup-security-fido2 2>/dev/null || \
    present_terminal "echo 'Fido2 security key setup is not yet available for Kali.\nSee: https://developers.yubico.com/libfido2/'" ;;
  *) show_setup_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(omari-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_system_menu() {
  local options=""

 if omari-toggle-enable suspend-off; then
    options="$optionsу°’І  Enable Suspend"
  else
    options="$optionsу°’І  Disable Suspend"
  fi

  case $(menu "System" "$options") in
  *Suspend*) omari-toggle-suspend ;;
  *) show_setup_menu ;;
  esac
}

show_setup_default_menu() {
  case $(menu "Default" "п’Ҳ  Browser\nп’ү  Terminal\nп…ң  Editor") in
  *Browser*) show_setup_default_browser_menu ;;
  *Terminal*) show_setup_default_terminal_menu ;;
  *Editor*) show_setup_default_editor_menu ;;
  *) show_setup_menu ;;
  esac
}

browser_desktop_exists() {
  [[ -f ~/.local/share/applications/$1 || -f ~/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

show_setup_default_browser_menu() {
  local options=""
  browser_desktop_exists chromium.desktop && options="$optionsпүЁ  Chromium"
  browser_desktop_exists google-chrome.desktop && options="${options:+$options\n}у°ҠҜ  Chrome"
  browser_desktop_exists brave-browser.desktop && options="${options:+$options\n}у°–ҹ  Brave"
  browser_desktop_exists microsoft-edge.desktop && options="${options:+$options\n}у°Ү©  Edge"
  browser_desktop_exists firefox.desktop && options="${options:+$options\n}у°Ҳ№  Firefox"
  browser_desktop_exists zen.desktop && options="${options:+$options\n}у°–ҹ  Zen"

  local current=""
  case "$(omari-default-browser)" in
  chromium) current="пүЁ  Chromium" ;;
  chrome) current="у°ҠҜ  Chrome" ;;
  brave) current="у°–ҹ  Brave" ;;
  edge) current="у°Ү©  Edge" ;;
  firefox) current="у°Ҳ№  Firefox" ;;
  zen) current="у°–ҹ  Zen" ;;
  esac

  case $(menu "Default Browser" "$options" "" "$current") in
  *Chromium*) omari-default-browser chromium ;;
  *Chrome*) omari-default-browser chrome ;;
  *Brave*) omari-default-browser brave ;;
  *Edge*) omari-default-browser edge ;;
  *Firefox*) omari-default-browser firefox ;;
  *Zen*) omari-default-browser zen ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_terminal_menu() {
  local options=""
  omari-cmd-present alacritty && options="$optionsоһ•  Alacritty"
  omari-cmd-present ghostty && options="${options:+$options\n}оһ•  Ghostty"
  omari-cmd-present kitty && options="${options:+$options\n}оһ•  Kitty"

  local current=""
  case "$(omari-default-terminal)" in
  alacritty) current="оһ•  Alacritty" ;;
  ghostty) current="оһ•  Ghostty" ;;
  kitty) current="оһ•  Kitty" ;;
  esac

  case $(menu "Default Terminal" "$options" "" "$current") in
  *Alacritty*) omari-default-terminal alacritty ;;
  *Ghostty*) omari-default-terminal ghostty ;;
  *Kitty*) omari-default-terminal kitty ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_editor_menu() {
  local options=""
  omari-cmd-present nvim && options="$optionsоҡ®  Neovim"
  omari-cmd-present code && options="${options:+$options\n}оЈҡ  VSCode"
  omari-cmd-present zeditor && options="${options:+$options\n}п…ң  Zed"
  omari-cmd-present vim && options="${options:+$options\n}оҳ«  Vim"

  local current=""
  case "$(omari-default-editor)" in
  nvim) current="оҡ®  Neovim" ;;
  code) current="оЈҡ  VSCode" ;;
  zed | zeditor) current="п…ң  Zed" ;;
  vim) current="оҳ«  Vim" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) omari-default-editor nvim ;;
  *VSCode*) omari-default-editor code ;;
  *Zed*) omari-default-editor zed ;;
  *Vim*) omari-default-editor vim ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "у°Ёі  Niri\nу°Ң§  Walker\nу°Қң  Waybar\nу°Ӯӣ  Mako\nп„ө  Starship\nоҜҲ  Tmux") in
  *Niri*) open_in_editor ~/.config/niri/config.kdl ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && omari-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omari-restart-waybar ;;
  *Mako*) open_in_editor ~/.config/mako/config && omari-restart-mako ;;
  *Starship*) open_in_editor ~/.config/starship.toml ;;
  *Tmux*) open_in_editor ~/.config/tmux/tmux.conf && omari-restart-tmux ;;
  *) show_setup_menu ;;
  esac
}

