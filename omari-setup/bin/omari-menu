show_remove_gaming_menu() {
  case $(menu "Remove" "пҶ¶  Steam\nп„ӣ  RetroArch\nу°Қі  Minecraft\nоҫ”  Lutris (Battle.net)\nуұ“ҹ  Heroic (Epic Games)\nу°Қ№  Moonlight (GameStream)\nу°ӮҜ  Xbox Controller") in
  *Steam*) present_terminal omari-remove-steam ;;
  *RetroArch*) remove "RetroArch" "retroarch" ;;
  *Minecraft*) present_terminal omari-remove-minecraft ;;
  *Lutris*) present_terminal omari-remove-lutris ;;
  *Heroic*) present_terminal omari-remove-heroic ;;
  *Moonlight*) present_terminal omari-remove-moonlight ;;
  *Xbox*) present_terminal omari-remove-xbox-controllers ;;
  *) show_remove_menu ;;
  esac
}

show_remove_menu() {
  case $(menu "Remove" "оҪІ  Package\nпүЁ  Web App\nп’ү  TUI\nоҜҸ  Style\nпүЁ  Browser\nу°ө®  Development\nп„ӣ  Gaming\nу°Ҹ“  Preinstalls") in
  *Package*) terminal omari-pkg-remove ;;
  *Web*) present_terminal omari-webapp-remove ;;
  *TUI*) present_terminal omari-tui-remove ;;
  *Style*) show_remove_style_menu ;;
  *Browser*) show_remove_browser_menu ;;
  *Development*) show_remove_development_menu ;;
  *Gaming*) show_remove_gaming_menu ;;
  *Preinstalls*) present_terminal omari-remove-preinstalls ;;
  *) show_main_menu ;;
  esac
}

