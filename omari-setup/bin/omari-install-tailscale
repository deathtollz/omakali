#!/bin/bash

# omari:summary=Install the Tailscale mesh VPN service and a web app for the Tailscale Admin Console.
# omari:requires-sudo=true

echo "Installing Tailscale..."

CODENAME=$(. /etc/os-release; echo "$VERSION_CODENAME")

if [[ ! -f /etc/apt/sources.list.d/tailscale.list ]]; then
  [[ -f /etc/apt/trusted.gpg.d/tailscale.gpg ]] && sudo rm /usr/share/keyrings/tailscale-archive-keyring.gpg
  curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/$CODENAME.noarmor.gpg | sudo tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null
  curl -fsSL https://pkgs.tailscale.com/stable/ubuntu/$CODENAME.tailscale-keyring.list | sudo tee /etc/apt/sources.list.d/tailscale.list >/dev/null
fi

sudo apt-get update
omari-pkg-add tailscale

echo -e "\nStarting Tailscale..."
sudo systemctl enable --now tailscaled.service
sudo tailscale up --accept-routes

omari-webapp-install "Tailscale" "https://login.tailscale.com/admin/machines" https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/tailscale-light.png
