#!/bin/bash

# omari:summary=Display brightness level using SwayOSD on the current monitor.
# omari:args=<0-100>
# omari:examples=omari swayosd brightness 0 | omari swayosd brightness 50 | omari swayosd brightness 100

percent="$1"

progress="$(LC_NUMERIC=C awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

omari-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
