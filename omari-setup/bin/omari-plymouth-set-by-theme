#!/bin/bash

# omari:summary=Set the Plymouth boot theme from an Omari theme
# omari:args=<theme-name>
# omari:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via omari-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: omari-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/omari/themes/$theme ]]; then
  theme_dir=~/.config/omari/themes/$theme
else
  theme_dir="$OMARI_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec omari-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
