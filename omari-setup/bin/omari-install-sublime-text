#!/bin/bash

# omari:summary=Install Sublime Text via APT repository

echo "Adding Sublime Text APT repository..."
curl -fsSL https://download.sublimetext.com/sublimehq-pub.gpg | sudo apt-key add - 2>/dev/null || \
  sudo gpg --dearmor <(curl -fsSL https://download.sublimetext.com/sublimehq-pub.gpg) -o /usr/share/keyrings/sublime-text.gpg

echo "deb https://download.sublimetext.com/ apt/stable/" | sudo tee /etc/apt/sources.list.d/sublime-text.list

sudo apt-get update -qq
sudo apt-get install -y sublime-text
