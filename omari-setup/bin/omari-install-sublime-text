#!/bin/bash

# omari:summary=Install Sublime Text editor
# omari:requires-sudo=true

echo "Installing Sublime Text..."
curl -fsSL https://download.sublimetext.com/sublimehq-pub.gpg | sudo gpg --dearmor -o /usr/share/keyrings/sublime-text.gpg 2>/dev/null || true
echo "deb [signed-by=/usr/share/keyrings/sublime-text.gpg] https://download.sublimetext.com/ apt/stable/" | sudo tee /etc/apt/sources.list.d/sublime-text.list
sudo apt-get update
omari-pkg-add sublime-text
