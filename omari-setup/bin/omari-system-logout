#!/bin/bash

# omari:summary=Log out after closing application windows
# omari:examples=omari logout | omari system logout
# omari:aliases=omari logout

nohup bash -c "sleep 2 && niri msg action quit" >/dev/null 2>&1 &

# Now close all windows
omari-niri-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
