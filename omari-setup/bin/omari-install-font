#!/bin/bash

# omari:summary=Install a font for use in the terminal and code editor.
# omari:args=<font>
# omari:examples=omari-install-font jetbrains-mono

if [[ -z $1 ]]; then
  echo "Usage: omadeb-install-font <font>" >&2
  exit 1
fi

mkdir -p ~/.local/share/fonts

case "$1" in
jetbrains-mono)
  if [[ ! -d ~/.local/share/fonts/JetBrainsMonoNerd ]]; then
    echo "Downloading JetBrainsMono Nerd Font..."
    mkdir -p /tmp/omari-font-jb
    curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.3.0/JetBrainsMono.zip" -o /tmp/omari-font-jb/JetBrainsMono.zip
    unzip -q -o /tmp/omari-font-jb/JetBrainsMono.zip -d /tmp/omari-font-jb/
    mkdir -p ~/.local/share/fonts/JetBrainsMonoNerd
    mv /tmp/omari-font-jb/*.ttf ~/.local/share/fonts/JetBrainsMonoNerd/ 2>/dev/null
    rm -rf /tmp/omari-font-jb
  fi
  ;;
iafonts)
  omari-pkg-add fonts-ia-writer-mono
  ;;
cascadia-mono)
  omari-pkg-add fonts-cascadia-mono-nf
  ;;
iosevka-nerd)
  if [[ ! -d ~/.local/share/fonts/IosevkaNerd ]]; then
    echo "Downloading Iosevka Nerd Font..."
    mkdir -p /tmp/omari-font-iosevka
    curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.3.0/Iosevka.zip" -o /tmp/omari-font-iosevka/Iosevka.zip
    unzip -q -o /tmp/omari-font-iosevka/Iosevka.zip -d /tmp/omari-font-iosevka/
    mkdir -p ~/.local/share/fonts/IosevkaNerd
    mv /tmp/omari-font-iosevka/*.ttf ~/.local/share/fonts/IosevkaNerd/ 2>/dev/null
    rm -rf /tmp/omari-font-iosevka
  fi
  ;;
mscore)
  omari-pkg-add ttf-mscorefonts-installer
  ;;
*)
  echo "Usage: omadeb-install-font <font>" >&2
  exit 1
  ;;
esac

fc-cache