#!/bin/bash

# omari:summary=Run a named hook from ~/.config/omari/hooks/<name> and ~/.config/omari/hooks/<name>.d/.
# omari:args=[name] [args...]

set -e

HOOK=$1
HOOK_PATH="$HOME/.config/omari/hooks/$1"
HOOK_DIR="$HOOK_PATH.d"
shift

if [[ -f $HOOK_PATH ]]; then
  bash "$HOOK_PATH" "$@" || echo "Hook failed: $HOOK_PATH"
fi

if [[ -d $HOOK_DIR ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -f $hook ]] || continue
    [[ $hook == *.sample ]] && continue
    bash "$hook" "$@" || echo "Hook failed: $hook"
  done
fi