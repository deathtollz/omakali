#!/bin/bash

# omari:summary=Apply the current theme to Chromium-based browsers.
# omari:hidden=true

CHROMIUM_THEME="$HOME/.config/omari/current/theme/chromium.theme"

if [[ ! -f $CHROMIUM_THEME ]]; then
  exit 0
fi

set_browser_theme() {
  local config_dir="$1"
  local local_state="$config_dir/Local State"

  [[ -d "$config_dir" ]] || return 0

  theme_color=$(jq -r '.colors.ntp_background // empty' "$CHROMIUM_THEME" 2>/dev/null)
  [[ -z "$theme_color" ]] && return 0

  mkdir -p "$config_dir"
  if [[ -f "$local_state" ]]; then
    jq --arg color "$theme_color" '.browser.theme.color = $color | .browser.theme.use_system = false' "$local_state" > "${local_state}.tmp" && mv "${local_state}.tmp" "$local_state"
  else
    echo "{\"browser\":{\"theme\":{\"color\":\"$theme_color\",\"use_system\":false}}}" > "$local_state"
  fi
}

set_browser_theme "$HOME/.config/chromium"
set_browser_theme "$HOME/.config/google-chrome"
set_browser_theme "$HOME/.config/google-chrome-beta"
set_browser_theme "$HOME/.config/google-chrome-unstable"
set_browser_theme "$HOME/.config/BraveSoftware/Brave-Browser"
set_browser_theme "$HOME/.config/edge"
