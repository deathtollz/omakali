#!/bin/bash

# omari:summary=Add or remove an EFI boot entry for Omari, allowing direct boot.
# omari:requires-sudo=true

if [[ ! -d /sys/firmware/efi ]]; then
  echo "Error: System is not booted in UEFI mode" >&2
  exit 1
fi

if ! efibootmgr &>/dev/null; then
  echo "Error: efibootmgr is not available or not functional" >&2
  exit 1
fi

if cat /sys/class/dmi/id/bios_vendor 2>/dev/null | grep -qi "American Megatrends"; then
  echo "Error: American Megatrends firmware may not safely support custom EFI entries" >&2
  exit 1
fi

if cat /sys/class/dmi/id/bios_vendor 2>/dev/null | grep -qi "Apple"; then
  echo "Error: Apple firmware uses its own boot manager" >&2
  exit 1
fi

existing_entry=$(efibootmgr | grep -E "^Boot[0-9A-Fa-f]+\*? omari([[:space:]]|$)" | head -1)

if [[ -n $existing_entry ]]; then
  boot_num=$(echo "$existing_entry" | sed -n 's/^Boot\([0-9A-Fa-f]\+\).*/\1/p')

  if gum confirm "Disable direct boot (remove Omari EFI entry)?"; then
    echo "Removing EFI boot entry $boot_num"
    sudo efibootmgr --bootnum "$boot_num" --delete-bootnum >/dev/null
  fi

  exit 0
else
  boot_source=$(findmnt -n -o SOURCE /boot 2>/dev/null || findmnt -n -o SOURCE /)
  disk=$(echo "$boot_source" | sed 's/p\?[0-9]*$//')
  part=$(echo "$boot_source" | grep -o 'p\?[0-9]*$' | sed 's/^p//')

  efi_file=""
  for f in /boot/efi/EFI/debian/grubx64.efi /boot/efi/EFI/kali/grubx64.efi /boot/efi/EFI/linux/grubx64.efi /boot/vmlinuz-*; do
    if [[ -f $f ]]; then
      efi_file="$f"
      break
    fi
  done

  if [[ -z $efi_file ]]; then
    efi_file="\\EFI\\debian\\grubx64.efi"
  fi

  loader=$(echo "$efi_file" | sed 's|/boot/efi||;s|/|\\\\|g')

  if gum confirm "Setup direct boot entry for Omari/Kali?"; then
    echo "Creating EFI boot entry"
    sudo efibootmgr --create \
      --disk "$disk" \
      --part "$part" \
      --label "Omari" \
      --loader "$loader"
  fi
fi
