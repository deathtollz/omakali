#!/bin/bash

# omari:summary=Prompt for text input with Walker
# omari:group=menu
# omari:name=input
# omari:args=prompt [walker args...]
# omari:examples=omari menu input Reminder|omari-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

omari-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
