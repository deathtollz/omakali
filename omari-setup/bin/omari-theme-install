#!/bin/bash

# omari:summary=Install a theme from a git repository.
# omari:args=[git-repo-url]
# omari:examples=omari theme install https://github.com/example/omari-example-theme.git

if [[ -z $1 ]]; then
  echo -e "\e[32mSee https://omakasui.org/themes\n\e[0m"
  REPO_URL=$(gum input --placeholder="Git repo URL for theme" --header="")
else
  REPO_URL="$1"
fi

if [[ -z $REPO_URL ]]; then
  exit 1
fi

THEMES_DIR="$HOME/.config/omari/themes"

# Strip user@host: prefix from scp-style SSH URLs so basename sees just the path
REPO_PATH="$REPO_URL"
[[ $REPO_PATH != *"://"* && $REPO_PATH == *:*/* ]] && REPO_PATH="${REPO_PATH#*:}"
THEME_NAME=$(basename "$REPO_URL" .git | sed -E 's/^(omari|omakasui)-//; s/-theme$//' | tr '[:upper:]' '[:lower:]')
THEME_PATH="$THEMES_DIR/$THEME_NAME"

# Remove existing theme if present
if [[ -d $THEME_PATH ]]; then
  rm -rf "$THEME_PATH"
fi

# Clone the repo directly to ~/.config/omari/themes
if ! git clone "$REPO_URL" "$THEME_PATH"; then
  echo "Error: Failed to clone theme repo."
  exit 1
fi

# Apply the new theme with omari-theme-set
omari-theme-set "$THEME_NAME"
