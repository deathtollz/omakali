#!/bin/bash

# omari:summary=Remove a supported browser and clean up Omari browser defaults
# omari:args=<chrome|brave|edge|firefox|zen>
# omari:examples=omari remove browser firefox | omari remove browser brave
# omari:requires-sudo=true

set_fallback_default_browser() {
  local current_browser
  current_browser=$(xdg-settings get default-web-browser)

  if [[ $current_browser != "$1" ]]; then
    return
  fi

  if omari-cmd-present chromium; then
    xdg-settings set default-web-browser chromium.desktop
    xdg-mime default chromium.desktop x-scheme-handler/http
    xdg-mime default chromium.desktop x-scheme-handler/https
    xdg-mime default chromium.desktop text/html
  fi
}

case $1 in
chrome)
  echo "Removing Chrome..."
  set_fallback_default_browser google-chrome.desktop
  omari-pkg-drop google-chrome-stable
  rm -f ~/.config/chrome-flags.conf
  sudo rm -f /etc/opt/chrome/policies/managed/color.json
  ;;
edge)
  echo "Removing Edge..."
  set_fallback_default_browser microsoft-edge.desktop
  omari-pkg-drop microsoft-edge-stable
  rm -f ~/.config/microsoft-edge-stable-flags.conf
  sudo rm -f /etc/opt/edge/policies/managed/color.json
  ;;
brave)
  echo "Removing Brave..."
  set_fallback_default_browser brave-browser.desktop
  omari-pkg-drop brave-browser
  rm -f ~/.config/brave-flags.conf

  if omari-pkg-missing brave-origin-beta-bin; then
    sudo rm -rf /etc/brave
  fi
  ;;
firefox)
  echo "Removing Firefox..."
  set_fallback_default_browser firefox.desktop
  omari-pkg-drop firefox-esr
  ;;
zen)
  echo "Removing Zen..."
  set_fallback_default_browser zen.desktop
  omari-pkg-drop zen-browser
  ;;
*)
  echo "Usage: omari-remove-browser <chrome|brave|edge|firefox|zen>"
  exit 1
  ;;
esac
