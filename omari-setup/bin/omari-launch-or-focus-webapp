#!/bin/bash

# omari:summary=Launch or focus on a given web app identified by the window-pattern.
# omari:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: omari-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="omari-launch-webapp $@"

exec omari-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
