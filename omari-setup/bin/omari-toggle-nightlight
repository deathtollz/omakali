#!/bin/bash

# omari:summary=Toggle a warm night-light filter (wlsunset) on and off.
# omari:examples=omari toggle nightlight

set -euo pipefail

command -v wlsunset >/dev/null 2>&1 || {
  omari-notification-send -g "󰌵" "Nightlight" "wlsunset is not installed" 2>/dev/null || \
    notify-send "Nightlight" "wlsunset is not installed" 2>/dev/null || true
  exit 1
}

if pgrep -x wlsunset >/dev/null; then
  pkill -x wlsunset || true
  omari-notification-send -g "󰌵" "Nightlight" "Off" 2>/dev/null || \
    notify-send "Nightlight" "Off" 2>/dev/null || true
else
  # Constant warm temperature (equal high/low temps => no day/night ramp,
  # so no geolocation is required).
  wlsunset -t 4000 -T 4000 >/dev/null 2>&1 &
  omari-notification-send -g "󰌵" "Nightlight" "On (4000K)" 2>/dev/null || \
    notify-send "Nightlight" "On" 2>/dev/null || true
fi
