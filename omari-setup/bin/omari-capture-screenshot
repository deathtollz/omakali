#!/bin/bash

# omari:summary=Take a screenshot (region by default) to a file and the clipboard.
# omari:args=[region|output|window]
# omari:examples=omari capture screenshot | omari capture screenshot output

set -euo pipefail

mode="${1:-region}"

shot_dir="$(xdg-user-dir PICTURES 2>/dev/null || echo "$HOME/Pictures")/Screenshots"
mkdir -p "$shot_dir"
file="$shot_dir/screenshot-$(date +%Y%m%d-%H%M%S).png"

case "$mode" in
  output | screen | monitor)
    name="$(niri msg --json focused-output 2>/dev/null | jq -r '.name // empty')"
    if [[ -n "$name" ]]; then
      grim -o "$name" "$file"
    else
      grim "$file"
    fi
    ;;
  window)
    # Niri's own screenshot UI handles window capture best.
    niri msg action screenshot-window >/dev/null 2>&1 && exit 0
    ;;
  region | *)
    geom="$(slurp 2>/dev/null)" || exit 0   # cancelled selection
    [[ -n "$geom" ]] || exit 0
    grim -g "$geom" "$file"
    ;;
esac

[[ -f "$file" ]] || exit 0
wl-copy <"$file"
omari-notification-send -g "󰹑" "Screenshot" "Copied to clipboard · $(basename "$file")" 2>/dev/null || \
  notify-send "Screenshot" "Saved $file" 2>/dev/null || true
