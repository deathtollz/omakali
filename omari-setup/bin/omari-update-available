#!/bin/bash

# omari:summary=Check whether a newer Omari version is available.

OMARI_PATH="${OMARI_PATH:-$HOME/.local/share/omari}"

# Get remote tag
latest_tag=$(git -C "$OMARI_PATH" ls-remote --tags origin | grep -v "{}" | awk '{print $2}' | sed 's#refs/tags/##' | sort -V | tail -n 1)
if [[ -z $latest_tag ]]; then
  echo "Error: Could not retrieve latest tag."
  exit 1
fi

# Get local tag at HEAD
current_tag=$(git -C "$OMARI_PATH" describe --tags HEAD 2>/dev/null)
if [[ -z $current_tag ]]; then
  echo "Error: Could not retrieve current tag."
  exit 1
fi

if [[ $current_tag != $latest_tag ]]; then
  echo "Omari update available ($latest_tag)"
  exit 0
else
  echo "Omari is up to date ($current_tag)"
  exit 1
fi
