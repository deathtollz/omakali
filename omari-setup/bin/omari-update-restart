#!/bin/bash

# omari:summary=Prompt for required reboot or service restarts after updates.

if [[ -f $HOME/.local/state/omari/reboot-required ]]; then
  echo
  gum confirm "Updates require reboot. Ready?" && omari-system-reboot
fi

for file in "$HOME"/.local/state/omari/restart-*-required; do
  if [[ -f $file ]]; then
    filename=$(basename "$file")
    service=$(echo "$filename" | sed 's/restart-\(.*\)-required/\1/')
    echo "Restarting $service"
    omari-state clear "$filename"
    omari-restart-"$service"
  fi
done
