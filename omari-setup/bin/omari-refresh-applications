#!/bin/bash

# omari:summary=Ensure all default .desktop, web apps, TUIs, and npm wrappers are installed.

# Copy and sync icon files
mkdir -p ~/.local/share/icons/hicolor/48x48/apps/
cp ~/.local/share/omari/applications/icons/*.png ~/.local/share/icons/hicolor/48x48/apps/
gtk-update-icon-cache ~/.local/share/icons/hicolor &>/dev/null

# Copy .desktop declarations
mkdir -p ~/.local/share/applications
cp ~/.local/share/omari/applications/*.desktop ~/.local/share/applications/
cp ~/.local/share/omari/applications/hidden/*.desktop ~/.local/share/applications/

# Refresh the webapps, TUIs, and npm wrappers
bash $OMARI_PATH/install/packaging/icons.sh
bash $OMARI_PATH/install/packaging/webapps.sh
bash $OMARI_PATH/install/packaging/tuis.sh
bash $OMARI_PATH/install/packaging/npm.sh

update-desktop-database ~/.local/share/applications
