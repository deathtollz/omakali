#!/bin/bash

# omari:summary=Edit, set, or reset About branding
# omari:group=branding
# omari:name=about
# omari:args=<image|text|reset>
# omari:examples=omari branding about image | omari branding about text | omari branding about reset

set -euo pipefail

SOURCE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}"

case "${1:-}" in
image)
  image=$(omari-menu-file "Pick png/svg from $SOURCE_DIR" "${SOURCE_DIR}" "svg png")
  if [[ -n $image ]] && omari-transcode-ascii "$image" ~/.config/omari/branding/about.txt --width 54 --height 26; then
    omari-launch-about >/dev/null 2>&1
  fi
  ;;
text)
  omari-launch-editor ~/.config/omari/branding/about.txt >/dev/null 2>&1 && omari-launch-about >/dev/null 2>&1
  ;;
reset)
  cp "$OMARI_PATH/icon.txt" ~/.config/omari/branding/about.txt && omari-launch-about >/dev/null 2>&1
  ;;
*)
  echo "Usage: omari-branding-about <image|text|reset>" >&2
  exit 1
  ;;
esac
